# ─── SyncSphere Events — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values

# Supabase project URL — find in: Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — find in: Dashboard → Settings → API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Notes ────────────────────────────────────────────────────────────────────
# 1. Create a new Supabase project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Copy your URL and anon key from Settings → API
# 4. Create the 'event-posters' storage bucket (or the schema.sql does it for you)
# 5. Run: npm install && npm run dev
